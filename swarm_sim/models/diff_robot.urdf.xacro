<?xml version="1.0"?>
<robot name="diff_robot" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:arg name="namespace" default="robot"/>
  <xacro:property name="ns" value="$(arg namespace)"/>

  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_sep" value="0.35"/>

  <link name="base_link">
    <visual><geometry><box size="0.4 0.3 0.15"/></geometry></visual>
    <collision><geometry><box size="0.4 0.3 0.15"/></geometry></collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <xacro:macro name="wheel" params="prefix y_reflect">
    <link name="${prefix}_wheel">
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="0.05"/></geometry>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="0.05"/></geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="0 ${y_reflect * wheel_sep/2} 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>
  <xacro:wheel prefix="left"  y_reflect="1"/>
  <xacro:wheel prefix="right" y_reflect="-1"/>

  <link name="caster">
    <visual><geometry><sphere radius="0.05"/></geometry></visual>
    <collision><geometry><sphere radius="0.05"/></geometry></collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <origin xyz="0.15 0 -0.05"/>
  </joint>
  <!-- Frictionless caster so it slides instead of resisting turns -->
  <gazebo reference="caster"><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <!-- Diff-drive system plugin (Gazebo Fortress / ignition-gazebo6) -->
  <gazebo>
    <plugin filename="ignition-gazebo-diff-drive-system"
            name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_sep}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <topic>/${ns}/cmd_vel</topic>
      <odom_topic>/${ns}/odom</odom_topic>
      <tf_topic>/${ns}/tf</tf_topic>
      <frame_id>${ns}/odom</frame_id>
      <child_frame_id>${ns}/base_link</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>
    </plugin>
  </gazebo>
</robot>
